{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hashbulla/deep-research/tests/schema/research-sources.schema.json",
  "title": "research-sources.json",
  "description": "Array of source records emitted by the deep-research skill. Derived from references/report-structure.md §3.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "url",
      "url_canonical",
      "url_punycode",
      "title",
      "publisher",
      "author",
      "published_date",
      "accessed_date",
      "domain_tier",
      "admiralty_reliability",
      "tavily_score",
      "retrieval_tool",
      "retrieval_query",
      "sub_questions",
      "primary_source",
      "notes"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^S[0-9]{3,}$"
      },
      "url": {
        "type": "string",
        "pattern": "^https?://"
      },
      "url_canonical": {
        "type": "string"
      },
      "url_punycode": {
        "type": "string"
      },
      "title": {
        "type": "string",
        "minLength": 1
      },
      "publisher": {
        "type": "string"
      },
      "author": {
        "type": ["string", "null"]
      },
      "published_date": {
        "type": ["string", "null"],
        "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
      },
      "accessed_date": {
        "type": "string",
        "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
      },
      "domain_tier": {
        "type": "integer",
        "minimum": 1,
        "maximum": 4
      },
      "admiralty_reliability": {
        "type": "string",
        "enum": ["A", "B", "C", "D", "E", "F"]
      },
      "tavily_score": {
        "type": ["number", "null"],
        "minimum": 0,
        "maximum": 1,
        "description": "Relevance score from tavily_search. Null when the retrieval tool does not return a score (tavily_extract, tavily_map, tavily_crawl, WebSearch fallback) — never fabricate one."
      },
      "retrieval_tool": {
        "type": "string",
        "enum": [
          "tavily_search",
          "tavily_research",
          "tavily_extract",
          "tavily_map",
          "tavily_crawl",
          "context7_query_docs",
          "gh_cli",
          "academic_api",
          "WebSearch",
          "scrapling_stealth"
        ]
      },
      "retrieval_status": {
        "type": "string",
        "enum": ["direct", "stealth", "robots_overridden", "blocked"],
        "description": "How the content was obtained relative to access obstacles. Audit metadata only — never affects the grade."
      },
      "doc_provenance": {
        "type": "object",
        "additionalProperties": false,
        "description": "Provenance for chunk-based documentation sources (Context7). The record's url field carries the canonical documentation URL the chunk maps to.",
        "required": ["library_id", "section"],
        "properties": {
          "library_id": { "type": "string", "minLength": 1 },
          "version": { "type": ["string", "null"] },
          "section": { "type": "string", "minLength": 1 }
        }
      },
      "account_provenance": {
        "type": "object",
        "additionalProperties": false,
        "description": "Account identity for account-based sources (social platforms). Drives account-derived reliability per methodology §6.",
        "required": ["platform", "handle", "verified"],
        "properties": {
          "platform": { "type": "string" },
          "handle": { "type": ["string", "null"] },
          "verified": { "type": "boolean" },
          "account_reliability_basis": { "type": "string" },
          "post_timestamp": { "type": ["string", "null"] }
        }
      },
      "retrieval_query": {
        "type": "string"
      },
      "sub_questions": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "minItems": 1
      },
      "primary_source": {
        "type": "boolean"
      },
      "credibility_overlay": {
        "type": "object",
        "additionalProperties": false,
        "description": "Optional third-party editorial-credibility overlay (MBFC static dataset, user-scope). Only present when the overlay dataset rated this domain.",
        "required": ["source", "action", "dataset_version"],
        "properties": {
          "source": { "type": "string", "enum": ["mbfc_static", "newsguard"] },
          "factual_reporting": { "type": ["string", "null"] },
          "bias": { "type": ["string", "null"] },
          "action": { "type": "string", "enum": ["none", "flag", "downgrade"] },
          "dataset_version": { "type": "string" }
        }
      },
      "notes": {
        "type": "string"
      }
    }
  }
}
