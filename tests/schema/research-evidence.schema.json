{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hashbulla/deep-research/tests/schema/research-evidence.schema.json",
  "title": "research-evidence.json",
  "description": "Array of claim records emitted by the deep-research skill. Derived from references/report-structure.md §4.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "claim_id",
      "claim_text",
      "section",
      "supporting_source_ids",
      "contradicting_source_ids",
      "admiralty_credibility",
      "label",
      "corroboration_count",
      "independent_tier12_count",
      "primary_source_present",
      "notes"
    ],
    "properties": {
      "claim_id": {
        "type": "string",
        "pattern": "^C[0-9]{3,}$"
      },
      "claim_text": {
        "type": "string",
        "minLength": 1
      },
      "section": {
        "type": "string"
      },
      "supporting_source_ids": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^S[0-9]{3,}$"
        }
      },
      "contradicting_source_ids": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^S[0-9]{3,}$"
        }
      },
      "admiralty_credibility": {
        "type": "integer",
        "minimum": 1,
        "maximum": 6
      },
      "label": {
        "type": "string",
        "enum": [
          "CONFIRMED",
          "PROBABLY TRUE",
          "POSSIBLY TRUE",
          "DOUBTFUL",
          "IMPROBABLE",
          "UNVERIFIED"
        ]
      },
      "corroboration_count": {
        "type": "integer",
        "minimum": 0
      },
      "independent_tier12_count": {
        "type": "integer",
        "minimum": 0
      },
      "primary_source_present": {
        "type": "boolean"
      },
      "notes": {
        "type": "string"
      }
    }
  }
}
