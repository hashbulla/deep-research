{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/hashbulla/deep-research/tests/schema/research-evidence.schema.json",
  "title": "research-evidence.json",
  "description": "Array of claim records emitted by the deep-research skill. Derived from references/report-structure.md §4.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "claim_id",
      "claim_text",
      "section",
      "supporting_source_ids",
      "contradicting_source_ids",
      "admiralty_credibility",
      "label",
      "corroboration_count",
      "independent_tier12_count",
      "primary_source_present",
      "notes"
    ],
    "properties": {
      "claim_id": {
        "type": "string",
        "pattern": "^C[0-9]{3,}$"
      },
      "claim_text": {
        "type": "string",
        "minLength": 1
      },
      "section": {
        "type": "string"
      },
      "supporting_source_ids": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^S[0-9]{3,}$"
        }
      },
      "contradicting_source_ids": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^S[0-9]{3,}$"
        }
      },
      "admiralty_credibility": {
        "type": "integer",
        "minimum": 1,
        "maximum": 6
      },
      "label": {
        "type": "string",
        "enum": [
          "CONFIRMED",
          "PROBABLY TRUE",
          "POSSIBLY TRUE",
          "DOUBTFUL",
          "IMPROBABLE",
          "UNVERIFIED"
        ]
      },
      "corroboration_count": {
        "type": "integer",
        "minimum": 0
      },
      "independent_tier12_count": {
        "type": "integer",
        "minimum": 0
      },
      "primary_source_present": {
        "type": "boolean"
      },
      "anchor": {
        "type": "object",
        "additionalProperties": false,
        "description": "Span-level grounding for the claim. Optional under the standard rigor profile; required on every claim under the critical profile (gate-enforced by scripts/verify_gates.py --rigor critical). verbatim_quote anchors web sources (Tavily content is reprocessed — char offsets have no stable referent); snapshot_char_range anchors persisted corpus documents.",
        "required": ["anchor_type"],
        "properties": {
          "anchor_type": {
            "type": "string",
            "enum": ["snapshot_char_range", "verbatim_quote"]
          },
          "doc_id": {
            "type": "string"
          },
          "char_range": {
            "type": ["array", "null"],
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 2,
            "maxItems": 2
          },
          "snapshot_sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "quote": {
            "type": "string",
            "minLength": 1,
            "maxLength": 600
          }
        },
        "allOf": [
          {
            "if": { "properties": { "anchor_type": { "const": "snapshot_char_range" } } },
            "then": { "required": ["doc_id", "char_range", "snapshot_sha256"] }
          },
          {
            "if": { "properties": { "anchor_type": { "const": "verbatim_quote" } } },
            "then": { "required": ["quote"] }
          }
        ]
      },
      "notes": {
        "type": "string"
      }
    }
  }
}
